<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Toolbar -->
    <sys:String x:Key="Str_AddMusic">♫  Add Music</sys:String>
    <sys:String x:Key="Str_ClearList">✕  Clear List</sys:String>
    <sys:String x:Key="Str_OpenFolder">📂  Open Folder</sys:String>
    <sys:String x:Key="Str_SearchPlaceholder">🔍 Search...</sys:String>

    <!-- Now Playing -->
    <sys:String x:Key="Str_NoSongPlaying">No song playing</sys:String>
    <sys:String x:Key="Str_UnknownArtist">Unknown Artist</sys:String>

    <!-- Playback Modes -->
    <sys:String x:Key="Str_ModeSequential">↻ Sequential</sys:String>
    <sys:String x:Key="Str_ModeShuffle">🔀 Shuffle</sys:String>
    <sys:String x:Key="Str_ModeSingleLoop">🔂 Single Loop</sys:String>

    <!-- Language Toggle Button -->
    <sys:String x:Key="Str_LangToggle">中</sys:String>

    <!-- System Tray -->
    <sys:String x:Key="Str_TrayPlayPause">▶ Play / Pause</sys:String>
    <sys:String x:Key="Str_TrayNext">⏭ Next</sys:String>
    <sys:String x:Key="Str_TrayExit">✕ Exit</sys:String>
    <sys:String x:Key="Str_TrayBalloonText">Running in background. Double-click to restore.</sys:String>

    <!-- File Dialog -->
    <sys:String x:Key="Str_FileDialogTitle">Select Music Files</sys:String>
    <sys:String x:Key="Str_FileDialogFilter">Audio Files (*.mp3;*.wav;*.flac)|*.mp3;*.wav;*.flac</sys:String>

    <!-- Error Messages -->
    <sys:String x:Key="Str_PlaybackError">Playback Error</sys:String>
    <sys:String x:Key="Str_PlaybackErrorMsg">Failed to play the selected file.\n\nDetails: {0}</sys:String>
    <sys:String x:Key="Str_FileNotFound">File Not Found</sys:String>
    <sys:String x:Key="Str_FileNotFoundMsg">The file no longer exists:\n{0}</sys:String>

</ResourceDictionary>
