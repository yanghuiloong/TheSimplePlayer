<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Toolbar -->
    <sys:String x:Key="Str_AddMusic">♫  添加音乐</sys:String>
    <sys:String x:Key="Str_ClearList">✕  清空列表</sys:String>
    <sys:String x:Key="Str_OpenFolder">📂  打开目录</sys:String>
    <sys:String x:Key="Str_SearchPlaceholder">🔍 搜索...</sys:String>

    <!-- Now Playing -->
    <sys:String x:Key="Str_NoSongPlaying">暂无播放</sys:String>
    <sys:String x:Key="Str_UnknownArtist">未知艺术家</sys:String>

    <!-- Playback Modes -->
    <sys:String x:Key="Str_ModeSequential">↻ 顺序播放</sys:String>
    <sys:String x:Key="Str_ModeShuffle">🔀 随机播放</sys:String>
    <sys:String x:Key="Str_ModeSingleLoop">🔂 单曲循环</sys:String>

    <!-- Language Toggle Button -->
    <sys:String x:Key="Str_LangToggle">EN</sys:String>

    <!-- System Tray -->
    <sys:String x:Key="Str_TrayPlayPause">▶ 播放 / 暂停</sys:String>
    <sys:String x:Key="Str_TrayNext">⏭ 下一首</sys:String>
    <sys:String x:Key="Str_TrayExit">✕ 退出</sys:String>
    <sys:String x:Key="Str_TrayBalloonText">在后台运行中，双击托盘图标恢复窗口。</sys:String>

    <!-- File Dialog -->
    <sys:String x:Key="Str_FileDialogTitle">选择音乐文件</sys:String>
    <sys:String x:Key="Str_FileDialogFilter">音频文件 (*.mp3;*.wav;*.flac)|*.mp3;*.wav;*.flac</sys:String>

    <!-- Error Messages -->
    <sys:String x:Key="Str_PlaybackError">播放错误</sys:String>
    <sys:String x:Key="Str_PlaybackErrorMsg">无法播放所选文件。\n\n详情: {0}</sys:String>
    <sys:String x:Key="Str_FileNotFound">文件未找到</sys:String>
    <sys:String x:Key="Str_FileNotFoundMsg">文件已不存在:\n{0}</sys:String>

</ResourceDictionary>
